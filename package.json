{
  "name": "mikavn-library",
  "private": true,
  "version": "0.1.1",
  "description": "Windows-first local Galgame and Visual Novel library manager built with Tauri, React, Rust, and SQLite.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/release/check-release-metadata.ps1",
    "release:check:strict": "powershell -ExecutionPolicy Bypass -File scripts/release/check-release-metadata.ps1 -StrictGitHubLinks",
    "release:validate": "powershell -ExecutionPolicy Bypass -File scripts/release/run-release-validation.ps1",
    "release:validate:strict": "powershell -ExecutionPolicy Bypass -File scripts/release/run-release-validation.ps1 -StrictGitHubLinks",
    "release:validate:core": "powershell -ExecutionPolicy Bypass -File scripts/release/run-release-validation.ps1 -StrictGitHubLinks -SkipBrowserSmoke -SkipLargeSmoke -SkipTauriBuild -SkipDesktopSmoke",
    "smoke:browser": "node scripts/playwright/page-qa-runner.cjs && node scripts/playwright/core-workflow-smoke.cjs",
    "smoke:large": "node scripts/playwright/large-library-smoke.cjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "smoke:desktop": "powershell -ExecutionPolicy Bypass -File scripts/desktop-smoke/run-desktop-smoke.ps1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.15"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  }
}
