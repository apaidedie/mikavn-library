{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MikaVN Library",
  "version": "0.1.1",
  "identifier": "dev.mikavn.library",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MikaVN Library",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: http: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPLOCALDATA/**",
            "$APPCACHE/**",
            "$PICTURE/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$EXE/../app-data/images/**"
          ],
          "deny": [
            "$APPDATA/**/mikavn.db",
            "$APPDATA/**/*.db",
            "$APPDATA/**/*.sqlite",
            "$APPDATA/**/*.sqlite3",
            "$APPDATA/**/logs/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "useLocalToolsDir": true,
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCREFEODkwOTFEMjc0ODgKUldTSWROS1JrTmpheTJXZ0JSSDNrRWFwaVkxaGRGajZjL3orYTY4NjBoYk00MVJMTG9Ca09GYnMK",
      "endpoints": ["https://github.com/apaidedie/mikavn-library/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
