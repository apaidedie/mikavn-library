{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MikaVN Library",
  "version": "0.1.1",
  "identifier": "dev.mikavn.library",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MikaVN Library",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: http: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPLOCALDATA/**",
            "$APPCACHE/**",
            "$PICTURE/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$EXE/../app-data/images/**",
            "E:\\MikaVN Library\\app-data\\images\\**"
          ],
          "deny": [
            "$APPDATA/**/mikavn.db",
            "$APPDATA/**/*.db",
            "$APPDATA/**/*.sqlite",
            "$APPDATA/**/*.sqlite3",
            "$APPDATA/**/logs/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "useLocalToolsDir": true,
    "icon": ["icons/icon.ico"]
  }
}
